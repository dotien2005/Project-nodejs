extends ../../layouts/default.pug
include ../../mixins/filterStatus.pug
include ../../mixins/formSearch.pug
include ../../mixins/pagination.pug


block main
  h1 Trang Sản Phẩm Admin
  p Đây là trang quản lý sản phẩm dành cho quản trị viên.

  .card.mb-3 
    .card-header Bộ lọc và Tìm kiếm 
    .card-body 
      .row
        .col-6 
          +filerStatus(filterStatus)
        .col-6 
          +form-Search(keyword)

  .card.mb-3 
    .card-header Danh sách sản phẩm
      .card-body 
        form(
          action=`/admin/products/change-multi?_method=PATCH`
          method ="POST"
          form-change-mutli 
        )
          .d-flex.align-items-start 
            .form-group 
              select(name="type" class="form-control")
                option(value="active") Hoạt động 
                option(Value="inactive") Dừng Hoạt Động 
            .form-group 
              input(
                type="text"
                name="ids"
                value=""
                class="form-control"
              )
            button(type="submit" class="btn btn-primary") Áp dụng

        table(
          class="table.table-hover.table-sm "
          checkbox-multi
        )
          thead 
            tr 
              th 
                input(type="checkbox" name="checkall")
              th STT 
              th Hình ảnh 
              th Tiêu đề
              th Giá
              th Trạng thái
              th Hành động
          tbody 
            each item, index in productsPug

              tr 
                td
                  input(
                    type="checkbox"
                    name="id"
                    value=item.id
                      )
                td #{index + 1}
                td 
                  img(
                    src=item.thumbnail
                    alt=item.title
                    width="100"
                    height="100"
                  )
                td #{item.title}
                td #{item.price} $
                td
                  if(item.status === 'active')
                    a(
                      href="javascript:;"
                      class="badge badge-success"
                      data-id=item.id
                      data-status=item.status
                      button-change-status
                      ) Hoạt động
                  else
                    a(
                      href="javascript:;" 
                      class="badge badge-danger"
                      data-id=item.id
                      data-status=item.status
                      button-change-status
                      ) Không hoạt động
                td 
                  a(href="#" class="btn btn-warning btn-sm") Sửa
                  a(href="#" class="btn btn-danger btn-sm ml-1") Xóa

  nav
    +paginationPug(objectPagination)
  form(
    action=""
    method="POST"
    id="form-change-status"
    data-path="/admin/products/change-status"
  )

  script(src="/admin/js/productStatus.js")
  script(src="/admin/js/productMulti.js")

