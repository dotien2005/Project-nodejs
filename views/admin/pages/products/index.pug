extends ../../layouts/default.pug
block main
  h1 Trang Sản Phẩm Admin
  p Đây là trang quản lý sản phẩm dành cho quản trị viên.

  .card.mb-3 
    .card-header Bộ lọc và Tìm kiếm 
    .card-body 
      .row
        .col-6 
          each item in filterStatus
            button(
              class=`btn btn-sm ml-1 btn-outline-success ${item.class}`
              button-status=item.status
            ) #{item.name}
        .col-6 
          form(id="form-search")
            .input-group 
              input.form-control(
                type="text" 
                name="keyword" 
                placeholder="Tìm kiếm sản phẩm..."

                )
              .input-group-append 
                button(
                  type="submit"
                  class= "btn btn-success"
                  ) Tìm kiếm

  .card.mb-3 
    .card-header Danh sách sản phẩm
      .card-body 
        table.table.table-hover.table-sm 
          thead 
            tr 
              th STT 
              th Hình ảnh 
              th Tiêu đề
              th Giá
              th Trạng thái
              th Hành động
          tbody 
            each item, index in productsPug
              tr 
                td #{index + 1}
                td 
                  img(
                    src=item.thumbnail
                    alt=item.title
                    width="100"
                    height="100"
                  )
                td #{item.title}
                td #{item.price} $
                td
                  if(item.status === 'active')
                    a(href="#" class="badge badge-success") Hoạt động
                  else
                    a(href="#" class="badge badge-danger") Không hoạt động
                td 
                  a(href="#" class="btn btn-warning btn-sm") Sửa
                  a(href="#" class="btn btn-danger btn-sm ml-1") Xóa


