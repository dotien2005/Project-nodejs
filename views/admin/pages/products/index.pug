extends ../../layouts/default.pug
include ../../mixins/filterStatus.pug
include ../../mixins/formSearch.pug
include ../../mixins/pagination.pug


block main
  h1 Trang Sản Phẩm Admin
  p Đây là trang quản lý sản phẩm dành cho quản trị viên.

  .card.mb-3 
    .card-header Bộ lọc và Tìm kiếm 
    .card-body 
      .row
        .col-6 
          +filerStatus(filterStatus)
        .col-6 
          +form-Search(keyword)

  .card.mb-3 
    .card-header Danh sách sản phẩm
      .card-body 
        table.table.table-hover.table-sm 
          thead 
            tr 
              th STT 
              th Hình ảnh 
              th Tiêu đề
              th Giá
              th Trạng thái
              th Hành động
          tbody 
            each item, index in productsPug
              tr 
                td #{index + 1}
                td 
                  img(
                    src=item.thumbnail
                    alt=item.title
                    width="100"
                    height="100"
                  )
                td #{item.title}
                td #{item.price} $
                td
                  if(item.status === 'active')
                    a(href="#" class="badge badge-success") Hoạt động
                  else
                    a(href="#" class="badge badge-danger") Không hoạt động
                td 
                  a(href="#" class="btn btn-warning btn-sm") Sửa
                  a(href="#" class="btn btn-danger btn-sm ml-1") Xóa

  nav
    +paginationPug(objectPagination)
